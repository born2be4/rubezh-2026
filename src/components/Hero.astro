---
import { RACE } from '@/data/race';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<section class="relative isolate overflow-hidden">
  <!-- grid backdrop -->
  <div class="absolute inset-0 bg-grid [background-size:40px_40px] opacity-60"></div>

  <!-- radial glow -->
  <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at 50% 20%, rgba(225,6,0,.25) 0%, transparent 55%), radial-gradient(ellipse at 80% 80%, rgba(255,204,0,.15) 0%, transparent 50%);"></div>

  <!-- tread texture -->
  <div class="absolute inset-x-0 bottom-0 h-40 tread opacity-40"></div>

  <!-- dust -->
  <div class="absolute inset-0 dust"></div>

  <div class="relative max-w-6xl mx-auto px-4 pt-16 md:pt-24 pb-28 md:pb-36">

    <!-- stage marker -->
    <div class="flex items-center gap-3 mb-6">
      <span class="chip border-racing-red text-racing-red">● {RACE.edition}</span>
      <span class="chip border-racing-yellow text-racing-yellow">{RACE.city}</span>
      <span class="chip border-asphalt-300 text-asphalt-200">{RACE.dateShort}</span>
    </div>

    <!-- Title -->
    <h1 class="hero-title text-[17vw] md:text-[11rem] leading-[0.85] uppercase">
      {RACE.title}
    </h1>

    <div class="flex items-end gap-6 mt-2">
      <div class="font-display text-racing-yellow text-[14vw] md:text-[9rem] leading-none">{RACE.version}</div>
      <div class="pb-3 md:pb-6">
        <div class="font-racing uppercase tracking-[0.3em] text-white text-sm md:text-lg">{RACE.subtitle}</div>
        <div class="font-racing uppercase tracking-widest text-asphalt-200 text-xs md:text-sm mt-1">{RACE.date} · {RACE.city}</div>
      </div>
    </div>

    <!-- CTAs -->
    <div class="mt-10 flex flex-wrap gap-4">
      <a href={RACE.registrationBot} target="_blank" rel="noopener" class="btn-racing">
        🏁 Зарегистрироваться
      </a>
      <a href={base + '/participants'} class="btn-ghost">
        Список участников →
      </a>
    </div>

  </div>

  <!-- Bottom checker flag -->
  <div class="absolute inset-x-0 bottom-0 h-3 checker opacity-90"></div>
</section>
