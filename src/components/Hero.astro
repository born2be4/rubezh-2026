---
import { RACE } from '@/data/race';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<section class="relative isolate overflow-hidden">
  <!-- Фоновая афиша (если лежит в /public/poster.jpg) -->
  <div class="absolute inset-0 pointer-events-none">
    <img src={base + '/poster.jpg'} alt="" aria-hidden="true"
         onerror="this.style.display='none'"
         class="absolute inset-0 w-full h-full object-cover opacity-25 scale-105" />
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 50% 50%, rgba(10,10,10,.4) 0%, rgba(5,5,5,.85) 70%, #050505 100%);"></div>
  </div>

  <!-- grid backdrop -->
  <div class="absolute inset-0 bg-grid [background-size:40px_40px] opacity-40"></div>

  <!-- radial glow (sunset tone как на афише) -->
  <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at 50% 20%, rgba(255,107,0,.22) 0%, transparent 55%), radial-gradient(ellipse at 80% 80%, rgba(225,6,0,.2) 0%, transparent 50%);"></div>

  <!-- tread texture -->
  <div class="absolute inset-x-0 bottom-0 h-40 tread opacity-40"></div>

  <!-- dust -->
  <div class="absolute inset-0 dust"></div>

  <div class="relative max-w-6xl mx-auto px-4 pt-16 md:pt-24 pb-28 md:pb-36 grid md:grid-cols-[1fr_auto] gap-10 items-end">

   <div>
    <!-- stage marker -->
    <div class="flex items-center gap-3 mb-6 flex-wrap">
      <span class="chip border-racing-red text-racing-red">● {RACE.edition}</span>
      <span class="chip border-racing-yellow text-racing-yellow">{RACE.city}</span>
      <span class="chip border-asphalt-300 text-asphalt-200">{RACE.dateShort}</span>
      <span class="chip border-white/30 text-white">Начало 10:00</span>
    </div>

    <!-- Title -->
    <h1 class="hero-title text-[17vw] md:text-[11rem] leading-[0.85] uppercase">
      {RACE.title}
    </h1>

    <div class="flex items-end gap-6 mt-2">
      <div class="font-display text-racing-yellow text-[14vw] md:text-[9rem] leading-none">{RACE.version}</div>
      <div class="pb-3 md:pb-6">
        <div class="font-racing uppercase tracking-[0.3em] text-white text-sm md:text-lg">{RACE.subtitle}</div>
        <div class="font-racing uppercase tracking-widest text-asphalt-200 text-xs md:text-sm mt-1">{RACE.date} · {RACE.city}</div>
      </div>
    </div>

    <!-- CTAs -->
    <div class="mt-10 flex flex-wrap gap-4">
      <a href={RACE.registrationBot} target="_blank" rel="noopener" class="btn-racing">
        🏁 Зарегистрироваться
      </a>
      <a href={base + '/participants'} class="btn-ghost">
        Список участников →
      </a>
    </div>
   </div>

   <!-- Poster thumbnail (если файл есть) -->
   <div class="hidden md:block relative">
     <div class="relative w-[260px] aspect-[2/3] rounded-lg overflow-hidden border-2 border-racing-yellow/70 shadow-[0_20px_60px_rgba(225,6,0,.35)] bg-asphalt-700">
       <img src={base + '/poster.jpg'} alt="Афиша"
            onerror="this.parentElement.parentElement.style.display='none'"
            class="absolute inset-0 w-full h-full object-cover" />
       <div class="absolute inset-x-0 bottom-0 h-2 stripe-warn"></div>
     </div>
     <div class="mt-3 text-center font-racing uppercase tracking-widest text-[10px] text-asphalt-300">Официальная афиша</div>
   </div>

  </div>

  <!-- Bottom checker flag -->
  <div class="absolute inset-x-0 bottom-0 h-3 checker opacity-90"></div>
</section>
