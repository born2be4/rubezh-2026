---
import type { RaceClass } from '@/data/race';
interface Props { cls: RaceClass; count: number; total: number; }
const { cls, count, total } = Astro.props;
const pct = total > 0 ? Math.round((count / total) * 100) : 0;
---
<div class="class-card group">
  <div class={`absolute -top-10 -right-10 w-32 h-32 rounded-full bg-gradient-to-br ${cls.color} opacity-20 blur-2xl group-hover:opacity-40 transition`}></div>

  <div class="flex items-start justify-between mb-3">
    <div>
      <div class="font-racing uppercase tracking-widest text-[11px] text-asphalt-200">КЛАСС</div>
      <div class="font-racing uppercase text-xl text-white mt-0.5">{cls.name}</div>
      <div class="text-xs text-asphalt-300 mt-0.5">{cls.description}</div>
    </div>
    <div class="text-3xl">{cls.icon}</div>
  </div>

  <div class="mt-4 flex items-end justify-between">
    <div>
      <div class="font-display text-5xl text-racing-yellow number-glow leading-none">{count.toString().padStart(2,'0')}</div>
      <div class="font-racing uppercase tracking-widest text-[10px] text-asphalt-300 mt-1">Участников</div>
    </div>
    <div class="font-racing text-sm text-asphalt-200">{pct}%</div>
  </div>

  <!-- Progress -->
  <div class="mt-3 h-1.5 w-full bg-asphalt-700 rounded-full overflow-hidden">
    <div class={`h-full bg-gradient-to-r ${cls.color}`} style={`width:${pct}%`}></div>
  </div>
</div>
